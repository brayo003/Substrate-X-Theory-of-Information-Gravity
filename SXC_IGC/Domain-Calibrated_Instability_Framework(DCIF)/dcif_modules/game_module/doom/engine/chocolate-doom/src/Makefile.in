@PROGRAM_PREFIX@server$(EXEEXT): $(@PROGRAM_PREFIX@server_OBJECTS) $(@PROGRAM_PREFIX@server_DEPENDENCIES) $(EXTRA_@PROGRAM_PREFIX@server_DEPENDENCIES) 
	@rm -f @PROGRAM_PREFIX@server$(EXEEXT)
	$(AM_V_CCLD)$(LINK) $(@PROGRAM_PREFIX@server_OBJECTS) $(@PROGRAM_PREFIX@server_LDADD) $(LIBS)

@PROGRAM_PREFIX@setup$(EXEEXT): $(@PROGRAM_PREFIX@setup_OBJECTS) $(@PROGRAM_PREFIX@setup_DEPENDENCIES) $(EXTRA_@PROGRAM_PREFIX@setup_DEPENDENCIES) 
	@rm -f @PROGRAM_PREFIX@setup$(EXEEXT)
	$(AM_V_CCLD)$(LINK) $(@PROGRAM_PREFIX@setup_OBJECTS) $(@PROGRAM_PREFIX@setup_LDADD) $(LIBS)

@PROGRAM_PREFIX@strife$(EXEEXT): $(@PROGRAM_PREFIX@strife_OBJECTS) $(@PROGRAM_PREFIX@strife_DEPENDENCIES) $(EXTRA_@PROGRAM_PREFIX@strife_DEPENDENCIES) 
	@rm -f @PROGRAM_PREFIX@strife$(EXEEXT)
	$(AM_V_CCLD)$(LINK) $(@PROGRAM_PREFIX@strife_OBJECTS) $(@PROGRAM_PREFIX@strife_LDADD) $(LIBS)
install-execgamesSCRIPTS: $(execgames_SCRIPTS)
	@$(NORMAL_INSTALL)
	@list='$(execgames_SCRIPTS)'; test -n "$(execgamesdir)" || list=; \
	if test -n "$$list"; then \
	  echo " $(MKDIR_P) '$(DESTDIR)$(execgamesdir)'"; \
	  $(MKDIR_P) "$(DESTDIR)$(execgamesdir)" || exit 1; \
	fi; \
	for p in $$list; do \
	  if test -f "$$p"; then d=; else d="$(srcdir)/"; fi; \
	  if test -f "$$d$$p"; then echo "$$d$$p"; echo "$$p"; else :; fi; \
	done | \
	sed -e 'p;s,.*/,,;n' \
	    -e 'h;s|.*|.|' \
	    -e 'p;x;s,.*/,,;$(transform)' | sed 'N;N;N;s,\n, ,g' | \
	$(AWK) 'BEGIN { files["."] = ""; dirs["."] = 1; } \
	  { d=$$3; if (dirs[d] != 1) { print "d", d; dirs[d] = 1 } \
	    if ($$2 == $$4) { files[d] = files[d] " " $$1; \
	      if (++n[d] == $(am__install_max)) { \
		print "f", d, files[d]; n[d] = 0; files[d] = "" } } \
	    else { print "f", d "/" $$4, $$1 } } \
	  END { for (d in files) print "f", d, files[d] }' | \
	while read type dir files; do \
	     if test "$$dir" = .; then dir=; else dir=/$$dir; fi; \
	     test -z "$$files" || { \
	       echo " $(INSTALL_SCRIPT) $$files '$(DESTDIR)$(execgamesdir)$$dir'"; \
	       $(INSTALL_SCRIPT) $$files "$(DESTDIR)$(execgamesdir)$$dir" || exit $$?; \
	     } \
	; done

uninstall-execgamesSCRIPTS:
	@$(NORMAL_UNINSTALL)
	@list='$(execgames_SCRIPTS)'; test -n "$(execgamesdir)" || exit 0; \
	files=`for p in $$list; do echo "$$p"; done | \
	       sed -e 's,.*/,,;$(transform)'`; \
	dir='$(DESTDIR)$(execgamesdir)'; $(am__uninstall_files_from_dir)

mostlyclean-compile:
	-rm -f *.$(OBJEXT)

distclean-compile:
	-rm -f *.tab.c

