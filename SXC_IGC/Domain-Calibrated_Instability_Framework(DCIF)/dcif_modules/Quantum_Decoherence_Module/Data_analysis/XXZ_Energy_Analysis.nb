Notebook[{

Cell[CellGroupData[{
Cell["Analysis functions", "Section",
 CellChangeTimes->{
  3.8776049140651894`*^9},ExpressionUUID->"a364d213-1df1-4d41-96de-\
f8d44e73a20a"],

Cell[BoxData[
 RowBox[{"\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"expFitRaw0B", "[", "Datalist_", "]"}], ":=", 
     RowBox[{"Block", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
        "fitData", ",", "tnlm", ",", "tparaInterval", ",", "tpars", ",", 
         "tar", ",", "tcr"}], "}"}], ",", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"fitData", "=", 
         RowBox[{"Table", "[", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{
             RowBox[{
              RowBox[{"2", "i"}], "-", "1"}], ",", 
             RowBox[{"Datalist", "[", 
              RowBox[{"[", "i", "]"}], "]"}]}], "}"}], ",", 
           RowBox[{"{", 
            RowBox[{"i", ",", 
             RowBox[{"Length", "[", "Datalist", "]"}]}], "}"}]}], "]"}]}], 
        ";", "\[IndentingNewLine]", 
        RowBox[{"tnlm", "=", 
         RowBox[{"NonlinearModelFit", "[", 
          RowBox[{"fitData", ",", 
           RowBox[{"{", 
            RowBox[{
             RowBox[{
              RowBox[{
               RowBox[{"(", 
                RowBox[{"-", "1"}], ")"}], "*", 
               RowBox[{"Exp", "[", 
                RowBox[{"a", "-", 
                 RowBox[{"b", " ", "x"}]}], "]"}]}], "+", "c"}], ",", 
             RowBox[{
              RowBox[{"a", ">", "0"}], "&&", 
              RowBox[{"b", ">", "0"}]}]}], "}"}], ",", 
           RowBox[{"{", 
            RowBox[{"a", ",", 
             RowBox[{"{", 
              RowBox[{"b", ",", "0.5"}], "}"}], ",", "c"}], "}"}], ",", "x", 
           ",", 
           RowBox[{"ConfidenceLevel", "\[Rule]", "0.6827"}]}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"Quiet", "[", 
         RowBox[{"tparaInterval", "=", 
          RowBox[{
          "tnlm", "[", "\"\<ParameterConfidenceIntervals\>\"", "]"}]}], "]"}],
         ";", "\[IndentingNewLine]", 
        RowBox[{"tpars", "=", 
         RowBox[{"tnlm", "[", "\"\<BestFitParameters\>\"", "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"tar", "=", 
         RowBox[{"Around", "[", 
          RowBox[{
           RowBox[{"tpars", "[", 
            RowBox[{"[", 
             RowBox[{"1", ",", "2"}], "]"}], "]"}], ",", 
           RowBox[{"{", 
            RowBox[{
             RowBox[{
              RowBox[{"tparaInterval", "[", 
               RowBox[{"[", 
                RowBox[{"1", ",", "1"}], "]"}], "]"}], "-", 
              RowBox[{"tpars", "[", 
               RowBox[{"[", 
                RowBox[{"1", ",", "2"}], "]"}], "]"}]}], ",", 
             RowBox[{
              RowBox[{"tparaInterval", "[", 
               RowBox[{"[", 
                RowBox[{"1", ",", "2"}], "]"}], "]"}], "-", 
              RowBox[{"tpars", "[", 
               RowBox[{"[", 
                RowBox[{"1", ",", "2"}], "]"}], "]"}]}]}], "}"}]}], "]"}]}], 
        ";", "\[IndentingNewLine]", 
        RowBox[{"tcr", "=", 
         RowBox[{"Around", "[", 
          RowBox[{
           RowBox[{"tpars", "[", 
            RowBox[{"[", 
             RowBox[{"3", ",", "2"}], "]"}], "]"}], ",", 
           RowBox[{"{", 
            RowBox[{
             RowBox[{
              RowBox[{"tparaInterval", "[", 
               RowBox[{"[", 
                RowBox[{"3", ",", "1"}], "]"}], "]"}], "-", 
              RowBox[{"tpars", "[", 
               RowBox[{"[", 
                RowBox[{"3", ",", "2"}], "]"}], "]"}]}], ",", 
             RowBox[{
              RowBox[{"tparaInterval", "[", 
               RowBox[{"[", 
                RowBox[{"3", ",", "2"}], "]"}], "]"}], "-", 
              RowBox[{"tpars", "[", 
               RowBox[{"[", 
                RowBox[{"3", ",", "2"}], "]"}], "]"}]}]}], "}"}]}], "]"}]}], 
        ";", "\[IndentingNewLine]", 
        RowBox[{"Return", "[", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"-", 
            RowBox[{"Exp", "[", "tar", "]"}]}], ",", "tcr"}], "}"}], "]"}], 
        ";"}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"InferEnergyExp0B", "[", 
      RowBox[{"listAB_", ",", "Ebell_"}], "]"}], ":=", 
     RowBox[{"(*", " ", 
      RowBox[{"slightly", " ", "improved", " ", "analysis"}], "*)"}], 
     RowBox[{"Module", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"a1", ",", "c1", ",", "a2", ",", "c2"}], "}"}], ",", 
       RowBox[{
        RowBox[{
         RowBox[{"{", 
          RowBox[{"a1", ",", "c1"}], "}"}], "=", 
         RowBox[{"expFitRaw0B", "[", 
          RowBox[{"listAB", "[", 
           RowBox[{"[", "1", "]"}], "]"}], "]"}]}], ";", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"a2", ",", "c2"}], "}"}], "=", 
         RowBox[{"expFitRaw0B", "[", 
          RowBox[{"listAB", "[", 
           RowBox[{"[", "2", "]"}], "]"}], "]"}]}], ";", 
        RowBox[{
         RowBox[{"a1", "*", 
          RowBox[{
           RowBox[{"(", 
            RowBox[{"Ebell", "-", "c2"}], ")"}], "/", "a2"}]}], "+", 
         "c1"}]}]}], "]"}]}], ";"}]}]}]], "Input",
 CellChangeTimes->{{3.877604329584753*^9, 3.8776043427793016`*^9}, {
   3.877604454373094*^9, 3.877604473715232*^9}, 3.87760489840113*^9},
 CellLabel->
  "In[175]:=",ExpressionUUID->"26970218-cb40-4bc3-9233-1e135fe7d2f1"]
}, Open  ]],

